{
  "name": "OnBod",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "argon2"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "argon2": "^0.45.0",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "mongoose": "^8.7.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "pino-pretty": "^13.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0"
  }
}
